<%- include('./partials/header') %>
<main class="container py-5">
  <h1>Messages</h1>
  <ul class="pt-4 list-unstyled">
    <% messages.forEach(function(message, index) { %>
    <li>
      <h3><%= message.text %></h3>
      <p class="m-0"><%= message.user %></p>
      <a class="navbar-brand d-inline-block mb-3" href="/message/<%= index %>"
        >View Details</a
      >
    </li>
    <% }) %>
  </ul>
</main>
<%- include('./partials/footer') %>
